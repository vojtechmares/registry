{
  "name": "@registry/root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A serverless OCI registry on Cloudflare",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter './apps/*' build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "dev": "pnpm --filter @registry/worker dev",
    "conformance": "./scripts/conformance.sh",
    "deploy": "pnpm --filter @registry/worker deploy"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
