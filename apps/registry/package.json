{
  "name": "@registry/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The OCI registry Worker: R2 blobs, D1 metadata, Durable Object upload sessions",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply registry --local",
    "db:migrate:remote": "wrangler d1 migrations apply registry --remote"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.1",
    "@registry/api-contract": "workspace:*",
    "@registry/cron": "workspace:*",
    "@registry/notifications": "workspace:*",
    "@registry/oci": "workspace:*",
    "@registry/oidc": "workspace:*",
    "@registry/projects": "workspace:*",
    "@registry/regex": "workspace:*",
    "@registry/registry-core": "workspace:*",
    "@registry/replication": "workspace:*",
    "@registry/retention": "workspace:*",
    "@registry/semver": "workspace:*",
    "@registry/signing": "workspace:*",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@types/json-schema": "^7.0.15",
    "@valibot/to-json-schema": "^1.7.1",
    "hono": "^4.12.27",
    "hono-openapi": "^1.3.0",
    "hono-rate-limiter": "^0.5.3",
    "openapi-types": "^12.1.3",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.0",
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.9.3",
    "vitest": "~3.2.4",
    "wrangler": "^4.104.0"
  }
}
